# Copy to .env and adjust for your setup.

# Physical NIC on the edge box that is wired into the BR2 test VLAN.
# Find it with:  ip -o link show   (e.g. eth0, enp1s0, end0)
PARENT_IFACE=eth0

# Must match the BR2 test network exactly (DHCP must be DISABLED on it).
SUBNET=192.168.77.0/24
GATEWAY=192.168.77.1
BROADCAST=192.168.77.255

# NOTE: the simulated hosts use 192.168.77.61-.63 (set in docker-compose.yml).
# If you change SUBNET, update those ipv4_address values to match.
